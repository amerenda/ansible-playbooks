## Komodo Periphery (archlinux)
## Ansible writes the real compose.env from this template, injecting the
## periphery passkey from Bitwarden Secrets Manager. compose.env is gitignored.
##
## Bundled here so setup-archlinux-komodo works before archlinux/komodo/ lands on
## origin/main; once the repo has the same file, git wins (copy uses force: no).

## Image base tag (matches mac-mini-m4 Komodo Core).
COMPOSE_KOMODO_IMAGE_TAG=2.1.2

## Timezone
TZ=America/New_York

## Periphery
PERIPHERY_ROOT_DIRECTORY=/etc/komodo
PERIPHERY_DISABLE_TERMINALS=false
PERIPHERY_SSL_ENABLED=true
PERIPHERY_LOGGING_PRETTY=false
PERIPHERY_PRETTY_STARTUP_CONFIG=false

## Disk mounts to include in Komodo stats — list actual mount points only.
## /etc/hostname is intentionally absent: it does not exist on Arch Linux (static
## hostname set via hostnamectl, not a plain file). /mnt/storage is the large data
## disk. Auto-detection covers / and /home; these are supplemental.
PERIPHERY_INCLUDE_DISK_MOUNTS=/mnt/storage,/mnt/storage/media/config

## Enable the periphery's inbound HTTP server on :8120.
## Core connects inward every 15 s (monitoring_interval) to check server health,
## pull container stats, run image prunes, and execute stack operations.
## NOTE: outbound mode (PERIPHERY_CORE_ADDRESSES) does not complete the v2.1.2
## handshake successfully via k3s ingress — use inbound only.
PERIPHERY_SERVER_ENABLED=true

## Shared secret with Komodo Core (mac-mini-m4) — Ansible replaces this from
## Bitwarden secret komodo-dean-passkey before docker compose up.
PERIPHERY_PASSKEYS=ANSIBLE_WILL_REPLACE_THIS
