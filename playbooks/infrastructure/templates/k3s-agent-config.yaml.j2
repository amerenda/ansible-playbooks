# k3s Agent Configuration
# Generated by Ansible for {{ inventory_hostname }}

# Server connection
server: "https://{{ k3s_server_ip }}:6443"
token: "{{ k3s_token | default(ansible_env.K3S_TOKEN) }}"

# Node configuration
node-name: "{{ inventory_hostname }}"
node-ip: "{{ ansible_host }}"

# Data directory
data-dir: "/var/lib/rancher/k3s"

# Logging
log: "/var/log/k3s-agent.log"

# Kubelet configuration for Longhorn-only node
# Memory reservations are tuned per-node via group_vars (default 128Mi
# for sub-1GB nodes like rpi3-0, 256Mi for larger nodes)
kubelet-arg:
  - "max-pods=110"
  - "kube-reserved=cpu={{ k3s_agent_kube_reserved_cpu | default('50m') }},memory={{ k3s_agent_kube_reserved_mem | default('128Mi') }}"
  - "system-reserved=cpu={{ k3s_agent_system_reserved_cpu | default('50m') }},memory={{ k3s_agent_system_reserved_mem | default('128Mi') }}"
  - "eviction-hard=memory.available<100Mi"
  - "eviction-soft=memory.available<200Mi"
  - "eviction-soft-grace-period=memory.available=2m"

# Node labels for Longhorn
# Note: node-role.kubernetes.io/* labels can't be set via kubelet --node-labels
# (reserved prefix). Apply them via kubectl in post-k3s.yml instead.
node-label:
  - "longhorn.io/storage=true"
  - "longhorn-storage=true"
