#!/bin/bash
# k3s etcd auto-recovery on boot
# Runs before k3s.service. Handles:
#   - Empty tmpfs after reboot (normal: peers available, do nothing)
#   - Full power loss (no peers: snapshot-recency-based restore)
#
# LEADER ELECTION: The node with the most recent snapshot restores first.
# With staggered snapshots (~100s apart), this minimizes data loss.
# Tiebreaker: priority index adds 10s per rank so identical-age snapshots
# still produce a deterministic winner.
#
# FULL POWER LOSS DETECTION: Once all peers are SSH-reachable but none
# have k3s up, we immediately declare full power loss and proceed to
# leader election. No point waiting for k3s that can't start without
# a restore. Max wait for peers to boot: 60s.
#
# RESTORE DELAY: Capped at 30s (down from 180s). Stagger between
# snapshots is ~100s, so 30s is enough for a fresher-snapshot node
# to win leader election ahead of a staler one.
#
# This node: {{ inventory_hostname }} (priority index {{ restore_priority.index(inventory_hostname) }})
# All controllers: {{ restore_priority | join(', ') }}
#
# Managed by ansible — do not edit manually.

set -euo pipefail

ETCD_MOUNT="{{ etcd_mount_dir }}"
ETCD_DATA_DIR="{{ etcd_data_dir }}"
SNAPSHOT_DIR="{{ snapshot_dir }}"
CONFIG="/etc/rancher/k3s/config.yaml"
LOG_TAG="k3s-etcd-recovery"
PRIORITY_INDEX={{ restore_priority.index(inventory_hostname) }}
ETCDCTL="{{ etcdctl_path }}"
ETCD_CERTS="--endpoints=https://127.0.0.1:2379 --cert=/var/lib/rancher/k3s/server/tls/etcd/server-client.crt --key=/var/lib/rancher/k3s/server/tls/etcd/server-client.key --cacert=/var/lib/rancher/k3s/server/tls/etcd/server-ca.crt"
NODE_IP="{{ ansible_host }}"
PEER_IPS=({{ controller_ips | difference([ansible_host]) | join(' ') }})

log() { logger -t "$LOG_TAG" "$1"; echo "$1"; }

# Ensure tmpfs is mounted
if ! mountpoint -q "$ETCD_MOUNT"; then
    log "Mounting tmpfs at $ETCD_MOUNT"
    mount "$ETCD_MOUNT"
fi

# If etcd data already exists, nothing to do
if [ -d "$ETCD_MOUNT/member" ]; then
    log "etcd data exists on tmpfs — no recovery needed"
    exit 0
fi

log "tmpfs is empty — checking if peers are available"

# Clean up stale state that would prevent rejoin
rm -rf "${ETCD_DATA_DIR}/etcd-tmp" 2>/dev/null || true
rm -f "${ETCD_DATA_DIR}/state.db" "${ETCD_DATA_DIR}/state.db-wal" "${ETCD_DATA_DIR}/state.db-shm" 2>/dev/null || true

# Check if any peer controller is reachable on port 6443 (k3s running)
check_peers() {
    for peer in "${PEER_IPS[@]}"; do
        if curl -sk --connect-timeout 3 "https://${peer}:6443/healthz" >/dev/null 2>&1; then
            log "Peer $peer is up — k3s will rejoin"
            return 0
        fi
    done
    return 1
}

# Check if a specific host is reachable (k3s API or SSH)
check_host_alive() {
    local host=$1
    curl -sk --connect-timeout 2 "https://${host}:6443/healthz" >/dev/null 2>&1 || \
    timeout 2 bash -c "echo >/dev/tcp/${host}/22" 2>/dev/null
}

# Remove stale etcd member and orphaned learners for this node from a peer.
# Without this, k3s fails with "duplicate node name found" on rejoin.
# Must also wipe local etcd dir to ensure completely fresh join.
remove_stale_members() {
    for peer in "${PEER_IPS[@]}"; do
        local PEER_CERTS="--endpoints=https://${peer}:2379 --cert=/var/lib/rancher/k3s/server/tls/etcd/server-client.crt --key=/var/lib/rancher/k3s/server/tls/etcd/server-client.key --cacert=/var/lib/rancher/k3s/server/tls/etcd/server-ca.crt"
        local MEMBERS
        # Find members matching this node's IP
        MEMBERS=$(ETCDCTL_API=3 "$ETCDCTL" $PEER_CERTS member list -w simple 2>/dev/null | grep "$NODE_IP" | cut -d',' -f1) || true
        # Find orphaned learner members (empty name from failed join attempts)
        local LEARNERS
        LEARNERS=$(ETCDCTL_API=3 "$ETCDCTL" $PEER_CERTS member list -w simple 2>/dev/null | awk -F', ' '$3 == "" {print $1}') || true
        local ALL_STALE="$MEMBERS $LEARNERS"
        local removed=false
        for member_id in $ALL_STALE; do
            [ -z "$member_id" ] && continue
            log "Removing stale etcd member $member_id from peer $peer"
            if ETCDCTL_API=3 "$ETCDCTL" $PEER_CERTS member remove "$member_id" 2>&1; then
                log "Removed member $member_id"
                removed=true
            else
                log "WARNING: Failed to remove member $member_id from peer $peer"
            fi
        done
        if [ "$removed" = true ]; then
            return 0
        fi
    done
    return 1
}

if check_peers; then
    if [ -x "$ETCDCTL" ]; then
        remove_stale_members || log "WARNING: Could not remove stale members — k3s may fail to rejoin"
    else
        log "WARNING: etcdctl not found at $ETCDCTL — cannot remove stale members"
    fi
    # Wipe etcd dir completely for a clean join
    rm -rf "${ETCD_MOUNT:?}"/* 2>/dev/null || true
    log "Cleaned etcd data — k3s will rejoin fresh"
    exit 0
fi

# --- No peers reachable — full power loss ---

log "No peers reachable — full power loss detected"

# Wait for peers to boot (SSH-reachable), checking for k3s on every iteration.
# As soon as all peers are SSH-alive but none have k3s up, we know it's a
# full power loss — k3s can't start on any peer without a restore, so there's
# no point waiting longer. Proceed immediately to leader election.
# Max wait: 60s (enough for RPis to finish booting to SSH).

BOOT_WAIT=0
MAX_BOOT_WAIT=12  # 12 * 5s = 60s
log "Waiting for peers to boot (up to 60s)..."

while [ $BOOT_WAIT -lt $MAX_BOOT_WAIT ]; do
    if check_peers; then
        log "A peer's k3s came up — will rejoin"
        exit 0
    fi

    all_alive=true
    for peer_ip in "${PEER_IPS[@]}"; do
        if ! check_host_alive "$peer_ip"; then
            all_alive=false
            break
        fi
    done

    if [ "$all_alive" = true ]; then
        log "All peers SSH-reachable, none have k3s — full power loss confirmed"
        break
    fi

    sleep 5
    BOOT_WAIT=$((BOOT_WAIT + 5))
done

# Final peer check before leader election
if check_peers; then
    log "Peer came up during boot wait — k3s will rejoin"
    exit 0
fi

# --- Snapshot-recency-based leader election ---
#
# Each node calculates a restore delay based on how old its latest snapshot is.
# The node with the freshest snapshot has the shortest delay and restores first.
# Other nodes see k3s come up during their longer delay and rejoin instead.
#
# delay = min(snapshot_age_seconds / 2, 30) + (priority_index * 10)
#
# Cap is 30s (not 180s): stagger between snapshots is ~100s, so 30s is
# enough for a fresher-snapshot node to beat a staler one. The 180s cap
# was burning 3 minutes unnecessarily on every full power loss recovery.
#
# The priority_index tiebreaker (10s per rank) ensures that if snapshots
# have identical ages (non-staggered), a deterministic winner is chosen
# without overriding real age differences (~100s per staggered interval).

# Find latest snapshot
LATEST=$(ls -t "${SNAPSHOT_DIR}"/etcd-snapshot-* 2>/dev/null | head -1)

if [ -z "$LATEST" ]; then
    log "ERROR: No snapshots found in $SNAPSHOT_DIR — cannot recover"
    exit 1
fi

# Calculate snapshot age
SNAPSHOT_MTIME=$(stat -c %Y "$LATEST")
NOW=$(date +%s)
SNAPSHOT_AGE=$((NOW - SNAPSHOT_MTIME))

# Calculate delay: fresher snapshot = shorter wait
AGE_DELAY=$((SNAPSHOT_AGE / 2))
if [ $AGE_DELAY -gt 30 ]; then
    AGE_DELAY=30
fi
TIEBREAKER=$((PRIORITY_INDEX * 10))
TOTAL_DELAY=$((AGE_DELAY + TIEBREAKER))

log "Latest snapshot: $LATEST (${SNAPSHOT_AGE}s old)"
log "Restore delay: ${TOTAL_DELAY}s (age-based: ${AGE_DELAY}s + tiebreaker: ${TIEBREAKER}s)"

# Wait the calculated delay, checking for peers every 5s
WAITED=0
while [ $WAITED -lt $TOTAL_DELAY ]; do
    if check_peers; then
        log "Peer restored first (fresher snapshot) — k3s will rejoin"
        exit 0
    fi
    sleep 5
    WAITED=$((WAITED + 5))
done

# One final check before committing to restore
if check_peers; then
    log "Peer restored just in time — k3s will rejoin"
    exit 0
fi

# --- This node is restoring ---

log "No peer restored during delay. Restoring from snapshot: $LATEST"

# Unmount tmpfs (cluster-reset renames the etcd dir, fails on mounted tmpfs)
umount "$ETCD_MOUNT" 2>/dev/null || true

# Clean any old etcd data on the SD card (exposed after unmounting tmpfs)
rm -rf "${ETCD_MOUNT:?}"/* 2>/dev/null || true
rm -rf "${ETCD_MOUNT}-old-"* 2>/dev/null || true

# Use a temp config without server: so k3s doesn't try to join a peer
# during cluster-reset. Safer than sed in-place — never touches the real config.
grep -v '^server:' "$CONFIG" > /tmp/k3s-reset-config.yaml
k3s server --cluster-reset --cluster-reset-restore-path="$LATEST" --config /tmp/k3s-reset-config.yaml
rm -f /tmp/k3s-reset-config.yaml

# Copy restored data into re-mounted tmpfs
cp -a "$ETCD_MOUNT" /tmp/etcd-restored
mount "$ETCD_MOUNT"
cp -a /tmp/etcd-restored/. "$ETCD_MOUNT/"
rm -rf /tmp/etcd-restored

# Clean up old etcd dirs left by cluster-reset
rm -rf "${ETCD_MOUNT}-old-"* 2>/dev/null || true
rm -rf "${ETCD_DATA_DIR}/etcd-tmp" 2>/dev/null || true

log "Snapshot restore complete — k3s will start, other nodes will rejoin"
