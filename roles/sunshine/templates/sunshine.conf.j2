# Sunshine configuration — AMD Radeon RX 9070 XT (gfx1201/RDNA 4)
# Managed by Ansible. Manual edits will be overwritten.

# ── Encoding ───────────────────────────────────────────────

# VA-API is the primary encoder for AMD GPUs on Linux.
encoder = vaapi

# HEVC (H.265) SDR — kept as fallback for clients that don't support AV1.
hevc_mode = 2

# AV1 SDR — enabled: RDNA 4 has hardware AV1 encode (VAProfileAV1Profile0),
# better compression per bit than HEVC — ideal for WiFi streaming.
av1_mode = 2

# ── Capture ────────────────────────────────────────────────

# kwin uses KDE's screencast API (lowest overhead on Plasma Wayland).
capture = kwin

# ── Display ───────────────────────────────────────────────

# Explicit DRM render node (only card1/renderD128 exists on this GPU).
adapter_name = /dev/dri/renderD128

# A headless krfb-virtualmonitor output, created fresh per session at the
# connecting client's exact requested resolution by sunshine-vdisplay-connect.sh
# (global_prep_cmd below) — physical outputs are disabled for the session and
# restored on disconnect. dd_resolution_option's automatic mode-switching does
# NOT work under capture=kwin (verified: zero display-device activity logged
# during a live session, output stayed pinned at the physical monitor's own
# resolution) — this sidesteps that entirely by capturing an output that's
# already the right size, rather than trying to resize one Sunshine can't
# control. Applies uniformly to every client (Steam Deck, 4K TV, bedroom TV)
# since this is a single global capture target, not per-app.
output_name = Virtual-SunshineHeadless

# ── Network / Quality ──────────────────────────────────────

# 0 = no server-side cap; Moonlight clients set their own bitrate target.
max_bitrate = 0

# 20% FEC overhead — recovers from WiFi packet bursts without retransmit stalls.
fec_percentage = 20

# ── Performance ───────────────────────────────────────────

minimum_fps_target = 0
min_threads = 4

# ── Logging ───────────────────────────────────────────────

log_path = /tmp/sunshine.log
min_log_level = 3

# ── Stream lifecycle hooks ────────────────────────────────
# On stream start: create+enable the virtual display at the client's requested
#   resolution and disable physical outputs, THEN switch to Couch virtual
#   desktop, dismiss the KDE lock screen, disable idle autolock.
# On stream end: reverse order — restore desktop/autolock, then restore
#   physical outputs and destroy the virtual display.
global_prep_cmd=[{"do":"/usr/local/bin/sunshine-vdisplay-connect.sh","undo":"/usr/local/bin/sunshine-vdisplay-disconnect.sh","elevated":false},{"do":"/usr/local/bin/sunshine-couch-prep.sh","undo":"/usr/local/bin/sunshine-couch-undo.sh","elevated":false}]
