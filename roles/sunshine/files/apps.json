{
    "apps": [
        {
            "image-path": "desktop.png",
            "name": "Desktop",
            "prep-cmd": [
                {
                    "do": "/usr/local/bin/sunshine-couch-prep.sh",
                    "undo": "/usr/local/bin/sunshine-couch-undo.sh",
                    "elevated": false
                }
            ]
        },
        {
            "detached": [
                "/usr/local/bin/launch-bigpicture.sh"
            ],
            "image-path": "steam.png",
            "name": "Steam Big Picture",
            "prep-cmd": [
                {
                    "do": "/usr/local/bin/sunshine-couch-prep.sh",
                    "undo": "/usr/local/bin/sunshine-couch-undo.sh",
                    "elevated": false
                }
            ]
        },
        {
            "cmd": "/usr/bin/MoonDeckStream",
            "image-path": "steam.png",
            "name": "MoonDeckStream",
            "prep-cmd": [
                {
                    "do": "/usr/local/bin/sunshine-couch-prep.sh",
                    "undo": "/usr/local/bin/sunshine-couch-undo.sh",
                    "elevated": false
                }
            ]
        }
    ],
    "env": {
        "PATH": "$(PATH):$(HOME)/.local/bin"
    }
}
